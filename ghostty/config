# ============================================
# GHOSTTY CONFIG
# ============================================
# Symlinked: ~/.config/ghostty/config -> this file
# ============================================

# --------------------------------------------
# THEME
# --------------------------------------------

theme = vscode-light.conf

# --------------------------------------------
# FONT
# --------------------------------------------

font-family = MesloLGS NF
font-size = 14

# --------------------------------------------
# WINDOW
# --------------------------------------------

window-padding-x = 12
window-padding-y = 10
window-padding-balance = true
scrollback-limit = 100000

# --------------------------------------------
# BEHAVIOR
# --------------------------------------------

mouse-hide-while-typing = true
copy-on-select = clipboard
shell-integration = detect
